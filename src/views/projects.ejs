<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <p>Explore our active service initiatives across local neighborhoods.</p>
        
        <div class="projects-container">
            <% if (projects && projects.length > 0) { %>
                <ul class="projects-list">
                    <% projects.forEach(project => { %>
                        <li>
                            <strong>
                                <%= new Date(project.project_date).toLocaleDateString('en-US', { 
                                    year: 'numeric', 
                                    month: 'long', 
                                    day: 'numeric' 
                                }) %>:
                            </strong> 
                            <%= project.title %> 
                            <span class="org-badge">(<%= project.organization_name %>)</span>
                            <p class="project-desc"><%= project.description %></p>
                            <small class="project-loc">📍 Location: <%= project.location %></small>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <p>No upcoming service projects found at this moment. Check back soon!</p>
            <% } %>
        </div>
    </main>
</body>
</html>
<%- include('partials/footer') %>